{
  "name": "@whatfontis/mcp",
  "version": "0.2.0",
  "description": "MCP server for WhatFontIs — identify fonts from images inside Claude Desktop, Claude Code, Cursor, and any other MCP-compatible AI client.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "whatfontis-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "fonts",
    "font-identification",
    "whatfontis",
    "ai-tools"
  ],
  "author": "WhatFontIs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/whatfontis/wfi-mcp.git"
  },
  "homepage": "https://www.whatfontis.com/mcp.html",
  "bugs": {
    "url": "https://github.com/whatfontis/wfi-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
